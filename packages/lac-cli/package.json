{
  "name": "@life-as-code/lac-cli",
  "version": "0.1.0",
  "description": "CLI for life-as-code — feature provenance tracking from the terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/majeanson/lac-cli.git"
  },
  "keywords": ["cli", "feature", "provenance", "lac", "life-as-code"],
  "type": "module",
  "bin": {
    "lac": "./bin/lac.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist",
    "dev": "tsdown src/index.ts --format esm --dts --out-dir dist --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "lint": "oxlint src",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@life-as-code/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "@types/prompts": "^2.4.9",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "^4.1.0"
  }
}
