{
  "name": "@majeanson/lac",
  "version": "3.6.0",
  "description": "CLI for life-as-code — feature provenance tracking from the terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/majeanson/lac-cli.git"
  },
  "keywords": [
    "cli",
    "feature",
    "provenance",
    "lac",
    "life-as-code"
  ],
  "type": "module",
  "bin": {
    "lac": "./bin/lac.js",
    "lac-lsp": "./bin/lac-lsp.js",
    "lac-mcp": "./bin/lac-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "lint": "oxlint src",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.50.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "prompts": "^2.4.2",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@life-as-code/feature-schema": "workspace:*",
    "@life-as-code/lac-claude": "workspace:*",
    "@life-as-code/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "@types/prompts": "^2.4.9",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "^4.1.0"
  }
}
