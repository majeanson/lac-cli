{
  "name": "@life-as-code/lac-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lac": "./bin/lac.js"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist",
    "dev": "tsdown src/index.ts --format esm --dts --out-dir dist --watch",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "lint": "oxlint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@life-as-code/feature-schema": "workspace:*",
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@life-as-code/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "@types/prompts": "^2.4.9",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "^4.1.0"
  }
}
