{
  "name": "lac-lens",
  "displayName": "life-as-code Lens",
  "description": "View feature provenance inline in your editor — code lens, hover, status bar, tree view, and rich panel for feature.json files.",
  "version": "3.0.0",
  "publisher": "majeanson",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/majeanson/lac-cli.git"
  },
  "keywords": [
    "feature",
    "provenance",
    "lac",
    "life-as-code",
    "codelens"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lacLens.openFeatureJson",
        "title": "lac: Open feature.json"
      },
      {
        "command": "lac.openFeatureJson",
        "title": "lac: Open feature.json"
      },
      {
        "command": "lacLens.showFeaturePanel",
        "title": "lac: Show Feature Panel"
      },
      {
        "command": "lacLens.createFeature",
        "title": "lac: New Feature here…",
        "icon": "$(add)"
      },
      {
        "command": "lacLens.createChildFeature",
        "title": "lac: New Child Feature…",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "lacLens.changeStatus",
        "title": "lac: Change Feature Status…",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "lacLens.searchFeatures",
        "title": "lac: Search Features…",
        "icon": "$(search)"
      },
      {
        "command": "lacLens.addDecision",
        "title": "lac: Add Decision…",
        "icon": "$(checklist)"
      },
      {
        "command": "lacLens.exportMarkdown",
        "title": "lac: Export Feature as Markdown",
        "icon": "$(markdown)"
      },
      {
        "command": "lacLens.refreshTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "lacLensFeatures",
          "name": "Features",
          "icon": "$(symbol-event)",
          "contextualTitle": "life-as-code Features"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "lacLens.createFeature",
          "when": "view == lacLensFeatures",
          "group": "navigation@1"
        },
        {
          "command": "lacLens.searchFeatures",
          "when": "view == lacLensFeatures",
          "group": "navigation@2"
        },
        {
          "command": "lacLens.refreshTree",
          "when": "view == lacLensFeatures",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "lacLens.showFeaturePanel",
          "when": "view == lacLensFeatures && viewItem == lacFeature",
          "group": "inline@1"
        },
        {
          "command": "lacLens.createChildFeature",
          "when": "view == lacLensFeatures && viewItem == lacFeature",
          "group": "lac@1"
        },
        {
          "command": "lacLens.changeStatus",
          "when": "view == lacLensFeatures && viewItem == lacFeature",
          "group": "lac@2"
        },
        {
          "command": "lacLens.exportMarkdown",
          "when": "view == lacLensFeatures && viewItem == lacFeature",
          "group": "lac@3"
        }
      ],
      "explorer/context": [
        {
          "command": "lacLens.createFeature",
          "group": "lacLens@1"
        },
        {
          "command": "lacLens.showFeaturePanel",
          "group": "lacLens@2",
          "when": "editorIsOpen"
        },
        {
          "command": "lacLens.openFeatureJson",
          "group": "lacLens@3",
          "when": "editorIsOpen"
        }
      ],
      "editor/context": [
        {
          "command": "lacLens.showFeaturePanel",
          "group": "lacLens@1",
          "when": "editorIsOpen"
        },
        {
          "command": "lacLens.createChildFeature",
          "group": "lacLens@2",
          "when": "editorIsOpen"
        },
        {
          "command": "lacLens.changeStatus",
          "group": "lacLens@3",
          "when": "editorIsOpen"
        },
        {
          "command": "lacLens.addDecision",
          "group": "lacLens@4",
          "when": "editorIsOpen"
        },
        {
          "command": "lacLens.exportMarkdown",
          "group": "lacLens@5",
          "when": "editorIsOpen"
        }
      ],
      "commandPalette": [
        { "command": "lacLens.createFeature" },
        { "command": "lacLens.createChildFeature" },
        { "command": "lacLens.changeStatus" },
        { "command": "lacLens.searchFeatures" },
        { "command": "lacLens.addDecision" },
        { "command": "lacLens.exportMarkdown" },
        { "command": "lacLens.showFeaturePanel" },
        { "command": "lacLens.refreshTree" }
      ]
    },
    "configuration": {
      "title": "life-as-code Lens",
      "properties": {
        "lacLens.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show feature CodeLens above first line of files in feature folders"
        },
        "lacLens.enableStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show active feature context in the status bar"
        },
        "lacLens.lspMode": {
          "type": "boolean",
          "default": false,
          "description": "Use the lac-lsp Language Server for richer hover, diagnostics, and workspace symbols. Requires lac-lsp to be installed (npm i -g @life-as-code/lac-lsp)."
        },
        "lacLens.lspServerPath": {
          "type": "string",
          "default": "lac-lsp",
          "description": "Path to the lac-lsp binary (defaults to 'lac-lsp' on PATH)"
        },
        "lacLens.httpPort": {
          "type": "number",
          "default": 7474,
          "description": "Port the lac-lsp HTTP API listens on (used for status bar blame in LSP mode)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vsce:package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@life-as-code/feature-schema": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "oxlint": "^1.39.0",
    "typescript": "^5.3.0"
  }
}
