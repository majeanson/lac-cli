{
  "name": "lac-cli",
  "private": true,
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo dev --continue",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "turbo": "^2.7.5"
  },
  "packageManager": "bun@1.3.0",
  "catalogs": {
    "prod": {
      "zod": "^4.3.5"
    },
    "dev": {
      "@types/node": "^25.0.9",
      "tsdown": "^0.19.0",
      "typescript": "^5.9.3"
    }
  },
  "dependencies": {
    "rolldown": "^1.0.0-rc.12"
  }
}
